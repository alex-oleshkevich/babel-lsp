# Maintainer: Alex Oleshkevich <techsupport@investerra.ch>
pkgbase=babel-lsp
pkgname=babel-lsp
pkgver=0.2.1
pkgrel=1
pkgdesc="Language server for Python Babel i18n (.po/.pot catalog diagnostics, completion, hover)"
arch=('x86_64' 'aarch64')
url="https://github.com/alex-oleshkevich/babel-lsp"
license=('MIT')
depends=()
provides=('babel-lsp')
conflicts=('babel-lsp')

source_x86_64=("${pkgname}-linux-x86_64::https://github.com/alex-oleshkevich/babel-lsp/releases/download/v${pkgver}/babel-lsp-linux-x86_64")
source_aarch64=("${pkgname}-linux-aarch64::https://github.com/alex-oleshkevich/babel-lsp/releases/download/v${pkgver}/babel-lsp-linux-aarch64")
sha256sums_x86_64=('SKIP')
sha256sums_aarch64=('SKIP')

package() {
    case "$CARCH" in
        x86_64)  install -Dm755 "${srcdir}/${pkgname}-linux-x86_64"  "${pkgdir}/usr/bin/babel-lsp" ;;
        aarch64) install -Dm755 "${srcdir}/${pkgname}-linux-aarch64" "${pkgdir}/usr/bin/babel-lsp" ;;
    esac
}
